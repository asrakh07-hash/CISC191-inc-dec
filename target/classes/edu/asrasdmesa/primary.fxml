<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.asrasdmesa.PrimaryController">

    <TextField fx:id="numberField" text="0" prefWidth="120" style="-fx-font-size: 20px;" />

    <HBox alignment="CENTER" spacing="15">
        <Button text="Increment" onAction="#increment" />
        <Button text="Decrement" onAction="#decrement" />
    </HBox>

</VBox>